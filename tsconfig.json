{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "esnext",
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "lib": [
      "dom",
      "es5",
      "scripthost",
      "es2015",
      "es2015.promise",
      "es2016.array.include",
      "es2018",
      "es2020",
      "es2022"
    ],
    "resolveJsonModule": true,
    "noEmit": true,
    "target": "esnext",
    "paths": {
      "@openmrs/esm-globals": ["./node_modules/@openmrs/esm-globals/dist/index.d.ts"],
      "@openmrs/esm-globals/src/*": ["./node_modules/@openmrs/esm-globals/dist/*"]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
